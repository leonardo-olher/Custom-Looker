/* ===== 1. REMOVER ELEMENTOS INDESEJADOS ===== */
/* Esconde o tooltip fixo e o SVG de background que o Looker gera */
#tooltip, 
#visSvg,
.hidden {
  display: none !important;
  visibility: hidden !important;
  opacity: 0 !important;
  height: 0 !important;
  pointer-events: none !important;
}

/* ===== 2. ESTRUTURA DA TABELA ===== */
.reportTable {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0 6px; /* Espaço entre as linhas para criar o efeito de blocos */
  font-family: "Open Sans", Arial, sans-serif;
  background-color: transparent !important;
}

/* ===== 3. HEADER (AZUL #1759FF) ===== */
.reportTable thead th {
  background-color: #1759ff !important;
  color: #ffffff !important;
  padding: 12px 16px;
  font-weight: 600;
  text-transform: uppercase;
  font-size: 12px;
  border: none;
}

/* Arredondamento apenas nas pontas do Header */
.reportTable thead tr th:first-child { border-radius: 10px 0 0 10px; }
.reportTable thead tr th:last-child { border-radius: 0 10px 10px 0; }

/* ===== 4. LINHAS E CÉLULAS (EFEITO BOLHA ÚNICA) ===== */
.reportTable tbody td {
  padding: 12px 16px;
  border-top: 1px solid #f1f3f7;
  border-bottom: 1px solid #f1f3f7;
  background-color: #ffffff; /* Fundo padrão das células */
}

/* Alternância de cores: Branco e Cinza muito claro */
.reportTable tbody tr:nth-child(even) td {
  background-color: #f9fafb;
}

/* Arredondando as pontas de cada linha para parecer uma bolha única */
.reportTable tbody tr td:first-child {
  border-left: 1px solid #f1f3f7;
  border-radius: 10px 0 0 10px;
}

.reportTable tbody tr td:last-child {
  border-right: 1px solid #f1f3f7;
  border-radius: 0 10px 10px 0;
}

/* Hover na linha inteira */
.reportTable tbody tr:hover td {
  background-color: #f0f4ff !important;
}

/* ===== 5. TOTAL (DESTAQUE CINZA ESCURO) ===== */
/* Selecionando as células que possuem a classe 'total' */
.reportTable td.total {
  background-color: #d1d5db !important; /* Cinza mais escuro solicitado */
  color: #111 !important;
  font-weight: 800 !important;
  border: none !important;
  padding: 14px 16px;
}

/* Garante o arredondamento na linha de total */
.reportTable tr:last-child td.total:first-child { border-radius: 10px 0 0 10px; }
.reportTable tr:last-child td.total:last-child { border-radius: 0 10px 10px 0; }

/* ===== 6. ALINHAMENTOS ===== */
.numeric { text-align: right; }
.nonNumeric { text-align: left; }
